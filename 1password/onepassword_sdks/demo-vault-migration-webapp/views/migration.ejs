<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Vault Migration | 1Password</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Sans:wght@300;400;500;600&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
  <style>
    :root {
      --bg-primary: #0f1419;
      --bg-secondary: #1a1f29;
      --bg-tertiary: #242b38;
      --bg-elevated: #2d3548;
      --accent-primary: #5b9bd5;
      --accent-secondary: #7eb5d6;
      --accent-success: #6ab187;
      --accent-warning: #d4a574;
      --accent-error: #d47a7a;
      --text-primary: #e4e7ed;
      --text-secondary: #a8afc0;
      --text-tertiary: #6e7689;
      --text-muted: #4d5361;
      --border-subtle: #2d3548;
      --border-normal: #3d4658;
      --shadow-sm: 0 1px 3px rgba(0, 0, 0, 0.3);
      --shadow-md: 0 4px 12px rgba(0, 0, 0, 0.4);
      --shadow-lg: 0 8px 24px rgba(0, 0, 0, 0.5);
      --space-xs: 0.25rem;
      --space-sm: 0.5rem;
      --space-md: 1rem;
      --space-lg: 1.5rem;
      --space-xl: 2rem;
      --font-sans: 'IBM Plex Sans', -apple-system, system-ui, sans-serif;
      --font-mono: 'JetBrains Mono', 'Courier New', monospace;
    }
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body {
      font-family: var(--font-sans);
      background: var(--bg-primary);
      color: var(--text-primary);
      line-height: 1.6;
      min-height: 100vh;
      overflow-x: hidden;
    }
    body::before {
      content: '';
      position: fixed;
      top: 0; left: 0; width: 100%; height: 100%;
      background: 
        radial-gradient(circle at 20% 20%, rgba(91, 155, 213, 0.05) 0%, transparent 50%),
        radial-gradient(circle at 80% 80%, rgba(107, 177, 135, 0.05) 0%, transparent 50%);
      pointer-events: none;
      z-index: 0;
    }
    .container { position: relative; z-index: 1; max-width: 1400px; margin: 0 auto; padding: var(--space-xl); }
    .header { margin-bottom: var(--space-xl); padding-bottom: var(--space-lg); border-bottom: 1px solid var(--border-subtle); }
    .header h1 { font-size: 2rem; font-weight: 600; color: var(--text-primary); margin-bottom: var(--space-sm); letter-spacing: -0.02em; }
    .header p { color: var(--text-secondary); font-size: 0.95rem; }
    .status-banner {
      background: var(--bg-secondary); border: 1px solid var(--border-normal); border-radius: 12px;
      padding: var(--space-lg); margin-bottom: var(--space-xl); display: none; box-shadow: var(--shadow-sm);
    }
    .status-banner.active { display: flex; align-items: center; justify-content: space-between; }
    .status-banner .status-info { display: flex; align-items: center; gap: var(--space-md); }
    .status-icon { width: 40px; height: 40px; border-radius: 8px; display: flex; align-items: center; justify-content: center; font-size: 1.2rem; background: var(--bg-elevated); }
    .status-icon.connected { background: rgba(107, 177, 135, 0.15); color: var(--accent-success); }
    .status-text h3 { font-size: 0.9rem; font-weight: 500; color: var(--text-primary); margin-bottom: var(--space-xs); }
    .status-text p { font-size: 0.85rem; color: var(--text-tertiary); }
    .card {
      background: var(--bg-secondary); border: 1px solid var(--border-normal); border-radius: 16px;
      padding: var(--space-xl); margin-bottom: var(--space-xl); box-shadow: var(--shadow-md); transition: all 0.3s ease;
    }
    .card:hover { border-color: var(--border-normal); box-shadow: var(--shadow-lg); }
    .card h2 { font-size: 1.3rem; font-weight: 600; color: var(--text-primary); margin-bottom: var(--space-sm); }
    .card .subtitle { color: var(--text-tertiary); font-size: 0.9rem; margin-bottom: var(--space-lg); }
    .form-group { margin-bottom: var(--space-lg); }
    .form-group label { display: block; font-size: 0.85rem; font-weight: 500; color: var(--text-secondary); margin-bottom: var(--space-sm); text-transform: uppercase; letter-spacing: 0.05em; }
    .form-group input {
      width: 100%; padding: var(--space-md); background: var(--bg-tertiary); border: 1px solid var(--border-subtle);
      border-radius: 8px; color: var(--text-primary); font-family: var(--font-mono); font-size: 0.9rem; transition: all 0.2s ease;
    }
    .form-group input:focus { outline: none; border-color: var(--accent-primary); background: var(--bg-elevated); box-shadow: 0 0 0 3px rgba(91, 155, 213, 0.1); }
    .form-group input::placeholder { color: var(--text-muted); }
    .help-text { font-size: 0.8rem; color: var(--text-tertiary); margin-top: var(--space-xs); font-style: italic; line-height: 1.5; }
    .btn {
      padding: var(--space-md) var(--space-xl); border: none; border-radius: 8px; font-size: 0.9rem; font-weight: 500;
      font-family: var(--font-sans); cursor: pointer; transition: all 0.2s ease; display: inline-flex; align-items: center; gap: var(--space-sm); text-decoration: none;
    }
    .btn-primary { background: var(--accent-primary); color: white; }
    .btn-primary:hover:not(:disabled) { background: var(--accent-secondary); transform: translateY(-1px); box-shadow: var(--shadow-md); }
    .btn-secondary { background: var(--bg-elevated); color: var(--text-primary); border: 1px solid var(--border-normal); }
    .btn-secondary:hover:not(:disabled) { background: var(--bg-tertiary); border-color: var(--accent-primary); }
    .btn:disabled { opacity: 0.5; cursor: not-allowed; transform: none; }
    .spinner { display: inline-block; width: 16px; height: 16px; border: 2px solid var(--text-muted); border-top-color: var(--accent-primary); border-radius: 50%; animation: spin 0.8s linear infinite; }
    @keyframes spin { to { transform: rotate(360deg); } }
    .progress-container { margin: var(--space-lg) 0; display: none; }
    .progress-container.active { display: block; }
    .progress-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: var(--space-sm); }
    .progress-label { font-size: 0.85rem; color: var(--text-secondary); font-weight: 500; }
    .progress-percentage { font-size: 0.85rem; color: var(--accent-primary); font-weight: 600; font-family: var(--font-mono); }
    .progress-stats { font-size: 0.8rem; color: var(--text-tertiary); margin-top: var(--space-xs); font-family: var(--font-mono); }
    .progress-bar-outer { width: 100%; height: 8px; background: var(--bg-tertiary); border-radius: 4px; overflow: hidden; box-shadow: inset 0 1px 3px rgba(0, 0, 0, 0.3); }
    .progress-bar-inner { height: 100%; background: linear-gradient(90deg, var(--accent-primary), var(--accent-secondary)); border-radius: 4px; width: 0%; transition: width 0.3s ease; box-shadow: 0 0 10px rgba(91, 155, 213, 0.5); }
    .vault-container { display: none; }
    .vault-container.active { display: block; }
    .vault-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: var(--space-lg); flex-wrap: wrap; gap: var(--space-md); }
    .vault-header h2 { font-size: 1.3rem; font-weight: 600; color: var(--text-primary); }
    .vault-actions { display: flex; gap: var(--space-sm); flex-wrap: wrap; align-items: center; }
    .search-box { position: relative; flex: 1; min-width: 300px; margin-bottom: var(--space-md); }
    .search-box input {
      width: 100%; padding: var(--space-md) var(--space-md) var(--space-md) 40px; background: var(--bg-tertiary);
      border: 1px solid var(--border-subtle); border-radius: 8px; color: var(--text-primary); font-size: 0.9rem;
    }
    .search-box::before { content: '🔍'; position: absolute; left: var(--space-md); top: 50%; transform: translateY(-50%); opacity: 0.5; }
    .vault-table-container { background: var(--bg-secondary); border: 1px solid var(--border-normal); border-radius: 12px; overflow: hidden; }
    .vault-table { width: 100%; border-collapse: collapse; }
    .vault-table thead { background: var(--bg-tertiary); }
    .vault-table th { padding: var(--space-md); text-align: left; font-size: 0.8rem; font-weight: 600; color: var(--text-tertiary); text-transform: uppercase; letter-spacing: 0.05em; border-bottom: 1px solid var(--border-normal); }
    .vault-table td { padding: var(--space-md); border-bottom: 1px solid var(--border-subtle); font-size: 0.9rem; }
    .vault-table tr:last-child td { border-bottom: none; }
    .vault-table tbody tr { transition: background 0.2s ease; }
    .vault-table tbody tr:hover { background: var(--bg-tertiary); }
    .vault-name { font-weight: 500; color: var(--text-primary); }
    .vault-id { font-family: var(--font-mono); font-size: 0.8rem; color: var(--text-tertiary); }
    .item-count { font-family: var(--font-mono); color: var(--accent-secondary); font-weight: 500; }
    .status-badge { display: inline-flex; align-items: center; gap: var(--space-xs); padding: var(--space-xs) var(--space-sm); border-radius: 6px; font-size: 0.8rem; font-weight: 500; }
    .status-badge.pending { background: rgba(168, 175, 192, 0.15); color: var(--text-tertiary); }
    .status-badge.personal { background: rgba(212, 165, 116, 0.15); color: var(--accent-warning); }
    .status-badge.preparing { background: rgba(212, 165, 116, 0.15); color: var(--accent-warning); }
    .status-badge.migrating { background: rgba(91, 155, 213, 0.15); color: var(--accent-primary); }
    .status-badge.success { background: rgba(107, 177, 135, 0.15); color: var(--accent-success); }
    .status-badge.error { background: rgba(212, 122, 122, 0.15); color: var(--accent-error); }
    .status-badge.warning { background: rgba(212, 165, 116, 0.15); color: var(--accent-warning); }
    .status-badge .spinner-small { width: 12px; height: 12px; border: 2px solid currentColor; border-top-color: transparent; border-radius: 50%; animation: spin 0.8s linear infinite; }
    .checkbox-wrapper { display: flex; align-items: center; justify-content: center; }
    input[type="checkbox"] { width: 18px; height: 18px; cursor: pointer; accent-color: var(--accent-primary); }
    .alert { padding: var(--space-md); border-radius: 8px; margin: var(--space-md) 0; display: flex; align-items: center; gap: var(--space-sm); font-size: 0.9rem; animation: slideIn 0.3s ease; }
    @keyframes slideIn { from { opacity: 0; transform: translateY(-10px); } to { opacity: 1; transform: translateY(0); } }
    .alert-success { background: rgba(107, 177, 135, 0.15); border: 1px solid var(--accent-success); color: var(--accent-success); }
    .alert-error { background: rgba(212, 122, 122, 0.15); border: 1px solid var(--accent-error); color: var(--accent-error); }
    .alert-warning { background: rgba(212, 165, 116, 0.15); border: 1px solid var(--accent-warning); color: var(--accent-warning); }
    .alert-info { background: rgba(91, 155, 213, 0.15); border: 1px solid var(--accent-primary); color: var(--accent-primary); }
    .migration-summary { background: var(--bg-tertiary); border-radius: 12px; padding: var(--space-lg); margin-top: var(--space-lg); display: none; }
    .migration-summary.active { display: block; animation: slideIn 0.3s ease; }
    .summary-title { font-size: 1.1rem; font-weight: 600; color: var(--text-primary); margin-bottom: var(--space-md); }
    .summary-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: var(--space-md); }
    .summary-item { background: var(--bg-elevated); padding: var(--space-md); border-radius: 8px; border: 1px solid var(--border-subtle); }
    .summary-item label { display: block; font-size: 0.8rem; color: var(--text-tertiary); margin-bottom: var(--space-xs); text-transform: uppercase; letter-spacing: 0.05em; }
    .summary-item .value { font-size: 1.5rem; font-weight: 600; font-family: var(--font-mono); }
    .summary-item.success .value { color: var(--accent-success); }
    .summary-item.error .value { color: var(--accent-error); }
    .summary-item.info .value { color: var(--accent-primary); }

    /* Debug toggle styles */
    .debug-toggle {
      display: flex;
      align-items: center;
      gap: var(--space-sm);
      padding: 6px 12px;
      background: var(--bg-elevated);
      border: 1px solid var(--border-normal);
      border-radius: 8px;
      cursor: pointer;
      user-select: none;
      transition: all 0.2s ease;
    }
    .debug-toggle:hover {
      border-color: var(--accent-primary);
      background: var(--bg-tertiary);
    }
    .debug-toggle.active {
      border-color: var(--accent-warning);
      background: rgba(212, 165, 116, 0.1);
    }
    .debug-toggle-label {
      font-size: 0.8rem;
      font-weight: 500;
      color: var(--text-tertiary);
      text-transform: uppercase;
      letter-spacing: 0.03em;
    }
    .debug-toggle.active .debug-toggle-label {
      color: var(--accent-warning);
    }
    .debug-switch {
      position: relative;
      width: 32px;
      height: 18px;
      flex-shrink: 0;
    }
    .debug-switch input {
      opacity: 0;
      width: 0;
      height: 0;
      position: absolute;
    }
    .debug-slider {
      position: absolute;
      cursor: pointer;
      inset: 0;
      background-color: var(--border-normal);
      border-radius: 18px;
      transition: 0.2s;
    }
    .debug-slider::before {
      content: "";
      position: absolute;
      height: 12px;
      width: 12px;
      left: 3px;
      bottom: 3px;
      background-color: var(--text-tertiary);
      border-radius: 50%;
      transition: 0.2s;
    }
    .debug-switch input:checked + .debug-slider {
      background-color: var(--accent-warning);
    }
    .debug-switch input:checked + .debug-slider::before {
      transform: translateX(14px);
      background-color: white;
    }

    @media (max-width: 768px) {
      .container { padding: var(--space-md); }
      .header h1 { font-size: 1.5rem; }
      .vault-header { flex-direction: column; align-items: stretch; }
      .vault-actions { width: 100%; }
      .btn { width: 100%; justify-content: center; }
      .debug-toggle { width: 100%; justify-content: center; }
      .vault-table { font-size: 0.85rem; }
      .vault-table th, .vault-table td { padding: var(--space-sm); }
    }
    ::-webkit-scrollbar { width: 8px; height: 8px; }
    ::-webkit-scrollbar-track { background: var(--bg-primary); }
    ::-webkit-scrollbar-thumb { background: var(--border-normal); border-radius: 4px; }
    ::-webkit-scrollbar-thumb:hover { background: var(--accent-primary); }
  </style>
</head>
<body>
  <div class="container">
    <div class="header">
      <h1>🔐 Vault Migration Tool</h1>
      <p>Securely migrate your 1Password vaults between accounts</p>
    </div>

    <div class="status-banner" id="statusBanner">
      <div class="status-info">
        <div class="status-icon connected">✓</div>
        <div class="status-text">
          <h3>Connected to 1Password</h3>
          <p>Source and destination accounts are ready</p>
        </div>
      </div>
      <button class="btn btn-secondary" onclick="editConnection()">Edit Connection</button>
    </div>

    <div class="card" id="connectionCard">
      <h2>Connect to 1Password</h2>
      <p class="subtitle" id="connectionSubtitle">Enter your service account tokens to begin migration</p>
      
      <!-- Service Account Form -->
      <form id="connectionForm">
        <div id="serviceAccountFields">
          <div class="form-group">
            <label for="sourceToken">Source Account Token</label>
            <input type="password" id="sourceToken" name="sourceToken" placeholder="ops_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx">
          </div>
          
          <div class="form-group">
            <label for="destToken">Destination Account Token</label>
            <input type="password" id="destToken" name="destToken" placeholder="ops_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx">
          </div>
        </div>

        <!-- Desktop Auth Fields -->
        <div id="desktopAuthFields" style="display: none;">
          <div class="form-group">
            <label for="sourceAccountName">Source Account Name</label>
            <input type="text" id="sourceAccountName" name="sourceAccountName" placeholder="e.g. My Team">
          </div>

          <div class="form-group">
            <label for="destAccountName">Destination Account Name</label>
            <input type="text" id="destAccountName" name="destAccountName" placeholder="e.g. New Company">
          </div>

          <div style="padding: 12px 16px; background: rgba(212, 165, 116, 0.1); border: 1px solid var(--accent-warning); border-radius: 8px; margin-bottom: var(--space-lg); font-size: 0.85rem; color: var(--text-secondary);">
            ⚠️ Desktop auth requires the 1Password desktop app running locally. The CLI (<code>op</code>) must be installed for vault creation. Docker is <strong>not supported</strong>.
          </div>
        </div>

        <div class="help-text" style="margin-bottom: var(--space-lg);">
          Items with CUSTOM categories will be automatically converted to Login items during migration, preserving all fields and concealed values.
          Personal/Private vaults (Employee vaults) are skipped when using service accounts — only shared vaults are migrated with "(Migrated)" appended to the name. With desktop auth, personal vault items are migrated to the destination's existing Private vault.
        </div>
        </div>
        
        <button type="submit" class="btn btn-primary" id="connectBtn">
          <span id="connectBtnText">Connect Accounts</span>
          <span id="connectSpinner" style="display: none;" class="spinner"></span>
        </button>
      </form>
      
      <div id="connectionError"></div>
    </div>

    <div class="vault-container" id="vaultContainer">
      <div class="vault-header">
        <h2>Source Vaults (<span id="vaultCount">0</span>)</h2>
        <div class="vault-actions">
          <button class="btn btn-primary" onclick="migrateSelected()" id="migrateSelectedBtn">Migrate Selected</button>
          <button class="btn btn-secondary" onclick="showAllVaults()" id="showAllVaultsBtn" style="display: none;">Show All Vaults</button>
          <button class="btn btn-secondary" onclick="downloadLogs()" id="downloadLogsBtn">📥 Download Logs</button>
        </div>
      </div>

      <div class="search-box" style="display: flex; align-items: center; gap: 1rem;">
        <input type="text" id="vaultSearch" placeholder="Search vaults by name or ID..." oninput="filterVaults()" style="flex: 1;">
        <span id="vaultSelectionCount" style="font-size: 0.85rem; color: var(--text-secondary); white-space: nowrap;"></span>
        <input type="text" id="globalSuffix" placeholder="Suffix for all vaults (optional)" style="padding: var(--space-md); background: var(--bg-tertiary); border: 1px solid var(--border-subtle); border-radius: 8px; color: var(--text-primary); font-size: 0.9rem; width: 260px;">
        <div class="debug-toggle" id="debugToggle" onclick="toggleDebug()" title="Enable verbose debug logging for all items in migration logs" style="flex-shrink: 0;">
          <label class="debug-switch">
            <input type="checkbox" id="debugCheckbox" onclick="event.stopPropagation()">
            <span class="debug-slider"></span>
          </label>
          <span class="debug-toggle-label">Debug</span>
        </div>
      </div>

      <div id="rateLimitBanner" style="display: none; padding: 0.75rem 1rem; border-radius: 8px; font-size: 0.85rem; margin-bottom: 1rem; line-height: 1.5;"></div>

      <div class="progress-container" id="progressContainer">
        <div class="progress-header">
          <span class="progress-label" id="progressLabel">Preparing migration...</span>
          <span class="progress-percentage" id="progressPercentage">0%</span>
        </div>
        <div class="progress-bar-outer">
          <div class="progress-bar-inner" id="progressBar"></div>
        </div>
        <div class="progress-stats" id="progressStats">
          Vaults: <span id="vaultsProgress">0/0</span> | 
          Items: <span id="itemsProgress">0/0</span>
        </div>
      </div>

      <div id="alertContainer"></div>

      <div class="vault-table-container">
        <table class="vault-table">
          <thead>
            <tr>
              <th style="width: 50px;"><input type="checkbox" id="selectAll" onchange="toggleSelectAll()"></th>
              <th>Vault Name</th>
              <th>Vault ID</th>
              <th>Type</th>
              <th>Items</th>
              <th>Suffix</th>
              <th>Status</th>
            </tr>
          </thead>
          <tbody id="vaultTableBody"></tbody>
        </table>
      </div>

      <div class="migration-summary" id="migrationSummary">
        <h3 class="summary-title">Migration Summary</h3>
        <div class="summary-grid">
          <div class="summary-item success"><label>Successful</label><div class="value" id="successCount">0</div></div>
          <div class="summary-item error"><label>Failed</label><div class="value" id="failureCount">0</div></div>
          <div class="summary-item info"><label>Total Items</label><div class="value" id="totalItems">0</div></div>
          <div class="summary-item info"><label>Total Vaults</label><div class="value" id="totalVaults">0</div></div>
        </div>
      </div>
    </div>
  </div>

  <script>
    let vaults = [];
    let selectedVaultIds = new Set();
    let isMigrating = false;
    let sourceToken = '';
    let destToken = '';
    let authMode = 'service-account';
    let sourceAccountName = '';
    let destAccountName = '';
    let totalVaultsToMigrate = 0;
    let completedVaults = 0;
    let totalItemsToMigrate = 0;
    let processedItems = 0;
    let completedItemsFromPriorVaults = 0;
    let migratedVaultIds = new Set();

    // Warn before page refresh/close during active migration
    window.addEventListener('beforeunload', (e) => {
      if (isMigrating) {
        e.preventDefault();
        e.returnValue = 'A migration is in progress. Refreshing will disconnect from the progress stream, but the migration will continue on the server. Are you sure?';
        return e.returnValue;
      }
    });

    
    const urlParams = new URLSearchParams(window.location.search);
    authMode = urlParams.get('authMode') || 'service-account';
    const useEnv = urlParams.get('useEnv') === 'true';

    
    document.addEventListener('DOMContentLoaded', () => {
      if (useEnv) {
        // Local Node.js with .env — auto-connect (works for both service-account and desktop modes)
        document.getElementById('serviceAccountFields').style.display = 'none';
        document.getElementById('desktopAuthFields').style.display = 'none';
        document.getElementById('connectionSubtitle').textContent = 'Connecting from .env...';
        autoConnectWithEnv();
      } else if (authMode === 'desktop') {
        document.getElementById('serviceAccountFields').style.display = 'none';
        document.getElementById('desktopAuthFields').style.display = 'block';
        document.getElementById('connectionSubtitle').textContent = 'Connect using 1Password desktop app integration';
      }
    });

    async function autoConnectWithEnv() {
      const connectBtn = document.getElementById('connectBtn');
      const connectBtnText = document.getElementById('connectBtnText');
      const connectSpinner = document.getElementById('connectSpinner');
      const errorDiv = document.getElementById('connectionError');
      const subtitle = document.getElementById('connectionSubtitle');

      
      document.getElementById('serviceAccountFields').style.display = 'none';
      document.getElementById('desktopAuthFields').style.display = 'none';
      connectBtn.disabled = true;
      connectBtnText.textContent = 'Connecting from .env...';
      connectSpinner.style.display = 'inline-block';
      if (subtitle) subtitle.textContent = 'Verifying .env credentials...';

      try {
        
        const envRes = await fetch('/migration/env-status');
        const envData = await envRes.json();

        if (!envData.loaded || !envData.ready) {
          
          document.getElementById('serviceAccountFields').style.display = 'block';
          if (subtitle) subtitle.textContent = '.env not found or incomplete — enter tokens manually';
          connectBtnText.textContent = 'Connect Accounts';
          connectBtn.disabled = false;
          connectSpinner.style.display = 'none';
          errorDiv.innerHTML = '<div class="alert alert-warning"><span>⚠️</span><span>.env file not loaded or missing required variables. Enter credentials manually.</span></div>';
          return;
        }

        
        if (envData.authMode === 'desktop') {
          authMode = 'desktop';
        }

        // Step 2: Connected — now gathering vault details
        const modeLabel = envData.authMode === 'desktop' ? 'desktop auth' : 'service account';
        connectBtnText.textContent = 'Gathering vault details...';
        if (subtitle) subtitle.textContent = `✓ Connected via ${modeLabel} — collecting vault information`;

        // Force DOM repaint before the slow network call
        await new Promise(r => requestAnimationFrame(() => requestAnimationFrame(r)));

        const response = await fetch('/migration/list-vaults', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ useEnvTokens: true })
        });
        const result = await response.json();
        if (result.success) {
          vaults = result.vaults;
          showVaultList();
          
          connectBtn.style.display = 'none';
          connectSpinner.style.display = 'none';
          const personalCount = vaults.filter(v => v.vaultType === 'personal').length;
          const sharedCount = vaults.length - personalCount;
          const displayLabel = envData.authMode === 'desktop' ? 'desktop auth' : '1Password Environments';
          let msg = `✓ Connected via ${displayLabel}! Found ${vaults.length} vaults`;
          if (personalCount > 0 && authMode === 'desktop') {
            msg += ` (${sharedCount} shared, ${personalCount} personal — personal vault items will migrate to existing Private vault)`;
          } else if (personalCount > 0) {
            msg += ` (${sharedCount} shared, ${personalCount} personal — personal vaults will be skipped)`;
          }
          showAlert('success', msg);
        } else {
          throw new Error(result.error || 'Failed to connect');
        }
      } catch (error) {
        document.getElementById('serviceAccountFields').style.display = 'block';
        if (subtitle) subtitle.textContent = 'Auto-connect failed — enter tokens manually';
        connectBtnText.textContent = 'Connect Accounts';
        connectBtn.disabled = false;
        connectSpinner.style.display = 'none';
        const errEl = document.createElement('div'); errEl.className = 'alert alert-error'; errEl.textContent = '⚠️ Failed to connect with .env: ' + error.message; errorDiv.innerHTML = ''; errorDiv.appendChild(errEl);
      }
    }
    
    document.getElementById('connectionForm').addEventListener('submit', handleConnect);

    
    async function initDebugToggle() {
      try {
        const res = await fetch('/migration/debug');
        const data = await res.json();
        applyDebugState(data.enabled);
      } catch (e) {
        console.warn('Could not fetch debug state:', e);
      }
    }

    async function toggleDebug() {
      const checkbox = document.getElementById('debugCheckbox');
      const newState = !checkbox.checked;
      try {
        const res = await fetch('/migration/debug', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ enabled: newState })
        });
        const data = await res.json();
        applyDebugState(data.enabled);
        showAlert('info', `🔧 Debug logging ${data.enabled ? 'enabled' : 'disabled'}`);
      } catch (e) {
        console.error('Failed to toggle debug:', e);
        showAlert('error', '✗ Failed to toggle debug mode');
      }
    }

    function applyDebugState(enabled) {
      const checkbox = document.getElementById('debugCheckbox');
      const toggle = document.getElementById('debugToggle');
      checkbox.checked = enabled;
      if (enabled) {
        toggle.classList.add('active');
      } else {
        toggle.classList.remove('active');
      }
    }

    initDebugToggle();
    
    async function handleConnect(e) {
      e.preventDefault();
      const connectBtn = document.getElementById('connectBtn');
      const connectBtnText = document.getElementById('connectBtnText');
      const connectSpinner = document.getElementById('connectSpinner');
      const errorDiv = document.getElementById('connectionError');
      const subtitle = document.getElementById('connectionSubtitle');
      
      if (authMode === 'desktop') {
        sourceAccountName = document.getElementById('sourceAccountName').value;
        destAccountName = document.getElementById('destAccountName').value;
        if (!sourceAccountName) {
          errorDiv.innerHTML = '<div class="alert alert-error"><span>⚠️</span><span>Source account name is required</span></div>';
          return;
        }
      } else {
        sourceToken = document.getElementById('sourceToken').value;
        destToken = document.getElementById('destToken').value;
      }
      
      connectBtn.disabled = true;
      connectBtnText.style.display = 'none';
      connectSpinner.style.display = 'inline-block';
      errorDiv.innerHTML = '';
      if (subtitle) subtitle.textContent = 'Connecting to 1Password...';
      
      try {
        const body = authMode === 'desktop'
          ? { authMode: 'desktop', sourceAccountName }
          : { serviceToken: sourceToken };

        // Update status before the potentially slow list-vaults call
        if (subtitle) subtitle.textContent = 'Connected — collecting vault details...';

        // Force DOM repaint before the slow network call
        await new Promise(r => requestAnimationFrame(() => requestAnimationFrame(r)));

        const response = await fetch('/migration/list-vaults', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(body)
        });
        const result = await response.json();
        if (result.success) {
          vaults = result.vaults;
          showVaultList();
          const personalCount = vaults.filter(v => v.vaultType === 'personal').length;
          const sharedCount = vaults.length - personalCount;
          let msg = `✓ Successfully connected! Found ${vaults.length} vaults`;
          if (personalCount > 0) {
            msg += ` (${sharedCount} shared, ${personalCount} personal — personal vaults will be skipped)`;
          }
          showAlert('success', msg);
        } else {
          throw new Error(result.error || 'Failed to connect');
        }
      } catch (error) {
        const errEl2 = document.createElement('div'); errEl2.className = 'alert alert-error'; errEl2.textContent = '⚠️ Failed to connect: ' + error.message; errorDiv.innerHTML = ''; errorDiv.appendChild(errEl2);
        if (subtitle) subtitle.textContent = 'Connection failed — check credentials and try again';
      } finally {
        connectBtn.disabled = false;
        connectBtnText.style.display = 'inline';
        connectSpinner.style.display = 'none';
      }
    }
    
    function showVaultList() {
      document.getElementById('connectionCard').style.display = 'none';
      document.getElementById('statusBanner').classList.add('active');
      document.getElementById('vaultContainer').classList.add('active');
      document.getElementById('vaultCount').textContent = vaults.length;
      renderVaults();
      updateSelectionCount();
    }
    
    function editConnection() {
      document.getElementById('connectionCard').style.display = 'block';
      document.getElementById('statusBanner').classList.remove('active');
      document.getElementById('vaultContainer').classList.remove('active');
    }
    
    let showSelectedOnly = false;

    function renderVaults() {
      const tbody = document.getElementById('vaultTableBody');
      const searchTerm = document.getElementById('vaultSearch').value.toLowerCase();
      let filteredVaults = vaults.filter(v => v.name.toLowerCase().includes(searchTerm) || v.id.toLowerCase().includes(searchTerm));
      
      // During migration, only show selected vaults
      if (showSelectedOnly) {
        filteredVaults = filteredVaults.filter(v => selectedVaultIds.has(v.id));
      } else {
        // Sort: selected first, then migrated, then the rest — each group alphabetical
        filteredVaults.sort((a, b) => {
          const aSelected = selectedVaultIds.has(a.id) ? 0 : 1;
          const bSelected = selectedVaultIds.has(b.id) ? 0 : 1;
          if (aSelected !== bSelected) return aSelected - bSelected;
          const aMigrated = migratedVaultIds.has(a.id) ? 0 : 1;
          const bMigrated = migratedVaultIds.has(b.id) ? 0 : 1;
          if (aMigrated !== bMigrated) return aMigrated - bMigrated;
          return a.name.localeCompare(b.name);
        });
      }
      
      tbody.innerHTML = filteredVaults.map(vault => {
        const isPersonal = vault.vaultType === 'personal';
        const isDesktop = authMode === 'desktop';
        const personalDisabled = isPersonal && !isDesktop;
        const wasMigrated = migratedVaultIds.has(vault.id);
        const statusId = `status-${vault.id}`;
        // Preserve current status if it was set during migration (success/error/etc)
        const existingStatus = document.getElementById(statusId);
        const currentStatusHtml = existingStatus && existingStatus.innerHTML !== 'Pending'
          ? existingStatus.outerHTML
          : `<span class="status-badge ${personalDisabled ? 'personal' : (wasMigrated ? 'success' : 'pending')}" id="${statusId}">${personalDisabled ? 'Skipped' : (wasMigrated ? '✓ Migrated' : 'Pending')}</span>`;

        return `
          <tr data-vault-id="${vault.id}" style="${personalDisabled ? 'opacity: 0.5;' : ''}">
            <td class="checkbox-wrapper">
              <input type="checkbox" class="vault-checkbox" value="${vault.id}" data-item-count="${vault.itemCount}"
                onchange="handleVaultSelection('${vault.id}', ${vault.itemCount})"
                ${selectedVaultIds.has(vault.id) ? 'checked' : ''} ${isMigrating || personalDisabled ? 'disabled' : ''}
                title="${personalDisabled ? 'Personal vaults cannot be migrated with service accounts' : (wasMigrated ? 'Already migrated this session — selecting will create duplicates' : '')}">
            </td>
            <td class="vault-name">${escapeHtml(vault.name)}</td>
            <td class="vault-id">${vault.id}</td>
            <td>${isPersonal
              ? (isDesktop
                ? '<span class="status-badge" style="background: rgba(91, 155, 213, 0.15); color: var(--accent-primary);">Personal</span>'
                : '<span class="status-badge personal">Personal</span>')
              : '<span class="status-badge" style="background: rgba(107, 177, 135, 0.15); color: var(--accent-success);">Shared</span>'
            }</td>
            <td class="item-count">${vault.itemCount}</td>
            <td>
              <input type="text" placeholder="optional"
                style="width:120px; padding:4px 8px; background:var(--bg-tertiary); border:1px solid var(--border-subtle); border-radius:6px; color:var(--text-primary); font-size:0.8rem;"
                value="${escapeHtml(vault.suffix || '')}"
                onchange="vaults.find(v=>v.id==='${vault.id}').suffix = this.value.trim()"
                ${isMigrating || personalDisabled ? 'disabled' : ''}>
            </td>
            <td>${currentStatusHtml}</td>
          </tr>
        `;
      }).join('');
    }
    
    function filterVaults() { renderVaults(); updateSelectionCount(); }

    function showAllVaults() {
      showSelectedOnly = false;
      document.getElementById('vaultSearch').value = '';
      document.getElementById('showAllVaultsBtn').style.display = 'none';
      renderVaults();
      updateSelectionCount();
    }
    
    function updateSelectionCount() {
      const el = document.getElementById('vaultSelectionCount');
      if (!el) return;
      const searchTerm = document.getElementById('vaultSearch').value.toLowerCase();
      const visibleCount = vaults.filter(v => v.name.toLowerCase().includes(searchTerm) || v.id.toLowerCase().includes(searchTerm)).length;
      const selectedCount = selectedVaultIds.size;
      if (searchTerm) {
        el.textContent = `${selectedCount} selected · ${visibleCount}/${vaults.length} shown`;
      } else {
        el.textContent = `${selectedCount} of ${vaults.length} selected`;
      }
    }
    
    function handleVaultSelection(vaultId, itemCount) {
      if (selectedVaultIds.has(vaultId)) {
        selectedVaultIds.delete(vaultId);
        totalItemsToMigrate -= itemCount;
      } else {
        selectedVaultIds.add(vaultId);
        totalItemsToMigrate += itemCount;
      }
      updateSelectAllCheckbox();
      updateSelectionCount();
    }
    
    function toggleSelectAll() {
      const selectAll = document.getElementById('selectAll');
      const checkboxes = document.querySelectorAll('.vault-checkbox:not([disabled])');
      if (selectAll.checked) {
        checkboxes.forEach(cb => {
          if (!selectedVaultIds.has(cb.value)) {
            selectedVaultIds.add(cb.value);
            totalItemsToMigrate += parseInt(cb.dataset.itemCount);
          }
          cb.checked = true;
        });
      } else {
        checkboxes.forEach(cb => {
          if (selectedVaultIds.has(cb.value)) {
            selectedVaultIds.delete(cb.value);
            totalItemsToMigrate -= parseInt(cb.dataset.itemCount);
          }
          cb.checked = false;
        });
      }
      updateSelectionCount();
    }
    
    function updateSelectAllCheckbox() {
      const selectAll = document.getElementById('selectAll');
      const checkboxes = document.querySelectorAll('.vault-checkbox:not([disabled])');
      const checkedCount = Array.from(checkboxes).filter(cb => cb.checked).length;
      selectAll.checked = checkedCount === checkboxes.length && checkboxes.length > 0;
      selectAll.indeterminate = checkedCount > 0 && checkedCount < checkboxes.length;
    }
    
    function updateVaultStatus(vaultId, status, message, showSpinner = false) {
      const statusBadge = document.getElementById(`status-${vaultId}`);
      if (!statusBadge) return;
      statusBadge.className = `status-badge ${status}`;
      statusBadge.innerHTML = showSpinner ? `<span class="spinner-small"></span> ${message}` : message;
    }
    
    function resetMigrationUI() {
      document.getElementById('progressBar').style.width = '0%';
      document.getElementById('progressPercentage').textContent = '0%';
      document.getElementById('progressLabel').textContent = 'Preparing migration...';
      document.getElementById('vaultsProgress').textContent = '0/0';
      document.getElementById('itemsProgress').textContent = '0/0';
      selectedVaultIds.forEach(vaultId => { updateVaultStatus(vaultId, 'pending', 'Pending'); });
      document.getElementById('migrationSummary').classList.remove('active');
      document.getElementById('alertContainer').innerHTML = '';
      document.getElementById('rateLimitBanner').style.display = 'none';
    }
    
    async function migrateSelected() {
      if (selectedVaultIds.size === 0) { showAlert('warning', '⚠️ Please select at least one vault to migrate'); return; }
      if (isMigrating) { showAlert('warning', '⚠️ Migration already in progress'); return; }

      
      const alreadyMigrated = [...selectedVaultIds].filter(id => migratedVaultIds.has(id));
      if (alreadyMigrated.length > 0) {
        const names = alreadyMigrated.map(id => {
          const v = vaults.find(v => v.id === id);
          return v ? `"${v.name}"` : id;
        }).join(', ');
        const proceed = confirm(
          `⚠️ Duplicate Migration Warning\n\n` +
          `${alreadyMigrated.length === 1 ? 'This vault was' : 'These vaults were'} already migrated in this session:\n` +
          `${names}\n\n` +
          `Migrating again will create duplicate items in the destination. ` +
          `Are you sure you want to proceed?`
        );
        if (!proceed) return;
      }

      
      resetMigrationUI();

      // --- Rate limit check (service account only) ---
      if (authMode !== 'desktop') {
        const selectedVaultList = vaults.filter(v => selectedVaultIds.has(v.id));
        const vaultItemCounts = selectedVaultList.map(v => v.itemCount);
        try {
          const rlRes = await fetch('/migration/rate-limit-check', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ vaultItemCounts })
          });
          const rl = await rlRes.json();
          if (rl.success) {
            const banner = document.getElementById('rateLimitBanner');
            if (rl.willExceed) {
              const proceed = confirm(
                `⚠️ Rate Limit Warning\n\n` +
                `This migration is estimated to use ~${rl.estimatedCalls} API write calls.\n` +
                `You have approximately ${rl.remaining} calls remaining in the current hour ` +
                `(${rl.used} already used).\n\n` +
                `This migration will likely hit the 1Password rate limit (1,000 writes/hour). ` +
                `If that happens, you may need to contact 1Password support or wait an hour before retrying.\n\n` +
                (rl.minutesUntilReset > 0 ? `Your rate limit window should reset in ~${rl.minutesUntilReset} minutes.\n\n` : '') +
                `Do you want to proceed anyway?`
              );
              if (!proceed) return;
              banner.style.display = 'block';
              banner.style.background = 'rgba(212, 165, 116, 0.12)';
              banner.style.border = '1px solid var(--accent-warning)';
              banner.style.color = 'var(--accent-warning)';
              banner.textContent = `⚠️ Estimated ~${rl.estimatedCalls} API calls (${rl.remaining} remaining this hour). This may hit the rate limit. If rate limited, contact 1Password support or wait an hour.`;
            } else {
              banner.style.display = 'block';
              banner.style.background = 'rgba(91, 155, 213, 0.1)';
              banner.style.border = '1px solid var(--accent-primary)';
              banner.style.color = 'var(--accent-primary)';
              banner.textContent = `📊 Estimated ~${rl.estimatedCalls} API calls (~${rl.remaining} remaining this hour). This should not hit the rate limit.` +
                (rl.used > 0 ? ` If you do experience rate limiting, wait an hour or contact 1Password support.` : '');
            }
          }
        } catch (e) {
          showAlert('info', '📊 Could not estimate rate limit usage. Proceeding with migration.');
        }
      }
      
      
      document.getElementById('vaultSearch').value = '';
      showSelectedOnly = true;
      document.getElementById('showAllVaultsBtn').style.display = 'inline-flex';
      renderVaults();
      updateSelectionCount();

      isMigrating = true;
      completedVaults = 0;
      processedItems = 0;
      completedItemsFromPriorVaults = 0;
      totalVaultsToMigrate = selectedVaultIds.size;
      
      totalItemsToMigrate = 0;
      vaults.forEach(v => { if (selectedVaultIds.has(v.id)) totalItemsToMigrate += v.itemCount; });
      
      const globalSuffix = document.getElementById('globalSuffix').value.trim();
      const selectedVaults = vaults.filter(v => selectedVaultIds.has(v.id)).map(v => ({ vaultId: v.id, vaultName: v.name, vaultType: v.vaultType || 'shared', suffix: v.suffix || globalSuffix }));
      
      const progressContainer = document.getElementById('progressContainer');
      progressContainer.classList.add('active');
      document.getElementById('progressLabel').textContent = 'Preparing migration...';
      document.getElementById('progressPercentage').textContent = '0%';
      document.getElementById('progressBar').style.width = '0%';
      updateProgressStats();
      document.getElementById('migrateSelectedBtn').disabled = true;
      
      let successCount = 0;
      let failureCount = 0;
      let totalItems = 0;

      // POST credentials to get a session ID — tokens never appear in URLs
      const startPayload = {
        authMode,
        vaults: selectedVaults
      };
      if (useEnv) {
        startPayload.useEnv = true;
      } else if (authMode === 'desktop') {
        startPayload.sourceAccountName = sourceAccountName;
        startPayload.destAccountName = destAccountName;
      } else {
        startPayload.sourceToken = sourceToken;
        startPayload.destToken = destToken;
      }

      let sessionId;
      try {
        const startRes = await fetch('/migration/start', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(startPayload)
        });
        const startData = await startRes.json();
        if (!startData.success) {
          showAlert('error', '✗ Failed to start migration session');
          document.getElementById('migrateSelectedBtn').disabled = false;
          isMigrating = false;
          return;
        }
        sessionId = startData.sessionId;
      } catch (e) {
        showAlert('error', '✗ Failed to start migration: ' + e.message);
        document.getElementById('migrateSelectedBtn').disabled = false;
        isMigrating = false;
        return;
      }

      const eventSource = new EventSource(`/migration/migrate-all-vaults?sessionId=${sessionId}`);
      
      eventSource.onopen = () => {
        document.getElementById('progressLabel').textContent = `Migrating ${totalVaultsToMigrate} vaults with ${totalItemsToMigrate} items...`;
        showAlert('info', `🚀 Starting migration of ${totalVaultsToMigrate} vaults...`);
      };
      
      eventSource.onmessage = (event) => {
        const data = JSON.parse(event.data);
        
        if (data.progress !== undefined && data.outcome) {
          const vaultId = data.outcome.vaultId;
          const phase = data.outcome.phase;
          
          
          if (phase === 'desktop-source-connect' || phase === 'desktop-dest-connect') {
            document.getElementById('progressLabel').textContent = data.outcome.message;
          } else if (phase === 'desktop-reading') {
            document.getElementById('progressLabel').textContent = data.outcome.message;
          } else if (phase === 'desktop-writing') {
            document.getElementById('progressLabel').textContent = data.outcome.message;
          } else if (phase === 'preparing') {
            document.getElementById('progressLabel').textContent = `Preparing vault "${data.outcome.vaultName}"...`;
            updateVaultStatus(vaultId, 'preparing', 'Preparing...', true);
          } else if (phase === 'migrating') {
            const ip = data.outcome.itemsProcessed || 0;
            const ti = data.outcome.totalItems || 0;
            document.getElementById('progressLabel').textContent = `Migrating "${data.outcome.vaultName}" (${ip}/${ti} items)...`;
            processedItems = completedItemsFromPriorVaults + ip;
            updateVaultStatus(vaultId, 'migrating', `Migrating (${ip}/${ti})`, false);
            updateProgressStats();
          } else if (phase === 'completed') {
            completedVaults++;
            const vaultItemCount = data.outcome.sourceItemCount || 0;
            completedItemsFromPriorVaults += vaultItemCount;
            processedItems = completedItemsFromPriorVaults;
            if (data.outcome.success) {
              migratedVaultIds.add(vaultId);
              updateVaultStatus(vaultId, 'success', `✓ Success (${data.outcome.successCount}/${vaultItemCount})`);
              successCount += data.outcome.successCount || 0;
            } else {
              const fc = data.outcome.failureCount || 0;
              updateVaultStatus(vaultId, fc > 0 ? 'error' : 'warning', `${fc > 0 ? '✗' : '⚠️'} ${fc} failed / ${vaultItemCount} items`);
              failureCount += fc;
              successCount += data.outcome.successCount || 0;
            }
            totalItems += vaultItemCount;
          } else if (phase === 'failed') {
            completedVaults++;
            const vaultItemCount = data.outcome.sourceItemCount || 0;
            completedItemsFromPriorVaults += vaultItemCount;
            processedItems = completedItemsFromPriorVaults;
            updateVaultStatus(vaultId, 'error', `✗ Failed: ${data.outcome.error || 'Unknown error'}`);
            failureCount += vaultItemCount;
          }
          
          updateProgress(data.progress);
          if (phase !== 'migrating') updateProgressStats();
        }
        
        if (data.finished) {
          eventSource.close();
          isMigrating = false;
          // Keep showSelectedOnly true — user can click "Show All Vaults" to see everything
          
          updateProgress(100);
          document.getElementById('migrateSelectedBtn').disabled = false;
          document.getElementById('successCount').textContent = successCount;
          document.getElementById('failureCount').textContent = failureCount;
          document.getElementById('totalItems').textContent = totalItems;
          document.getElementById('totalVaults').textContent = selectedVaults.length;
          document.getElementById('migrationSummary').classList.add('active');
          document.getElementById('progressLabel').textContent = 'Migration complete!';
          
          
          if (data.rateLimit) {
            const banner = document.getElementById('rateLimitBanner');
            const rl = data.rateLimit;
            banner.style.display = 'block';
            banner.style.background = 'rgba(107, 177, 135, 0.1)';
            banner.style.border = '1px solid var(--accent-success)';
            banner.style.color = 'var(--accent-success)';
            banner.textContent = `✓ Migration used ${rl.used} API calls this hour. ~${rl.remaining} calls remaining.` +
              (rl.remaining < 200 ? ` If you need to run another migration and hit a rate limit, wait an hour or contact 1Password support.` : '');
          }

          showAlert(data.success ? 'success' : 'warning', `${data.success ? '✓' : '⚠️'} ${data.message}`);
          setTimeout(() => { progressContainer.classList.remove('active'); }, 1500);
          updateSelectionCount();
        }
      };
      
      eventSource.onerror = () => {
        eventSource.close();
        isMigrating = false;
        showSelectedOnly = false;
        document.getElementById('migrateSelectedBtn').disabled = false;
        showAlert('error', '✗ Migration failed. Please check the logs for details.');
        progressContainer.classList.remove('active');
        renderVaults();
      };
    }
    
    function updateProgress(percentage) {
      document.getElementById('progressBar').style.width = `${percentage}%`;
      document.getElementById('progressPercentage').textContent = `${Math.round(percentage)}%`;
    }
    
    function updateProgressStats() {
      document.getElementById('vaultsProgress').textContent = `${completedVaults}/${totalVaultsToMigrate}`;
      document.getElementById('itemsProgress').textContent = `${Math.round(processedItems)}/${totalItemsToMigrate}`;
    }
    
    async function downloadLogs() {
      try { window.location.href = '/migration/download-log'; showAlert('success', '📥 Log file downloaded successfully'); }
      catch (error) { showAlert('error', '✗ Failed to download logs'); }
    }
    
    function showAlert(type, message, duration = null) {
      const container = document.getElementById('alertContainer');
      const alertDiv = document.createElement('div');
      alertDiv.className = `alert alert-${type}`;
      const icon = type === 'success' ? '✓' : type === 'error' ? '✗' : type === 'warning' ? '⚠️' : 'ℹ️';
      const iconSpan = document.createElement('span');
      iconSpan.textContent = icon;
      const msgSpan = document.createElement('span');
      msgSpan.textContent = message;
      alertDiv.appendChild(iconSpan);
      alertDiv.appendChild(msgSpan);
      container.appendChild(alertDiv);
      const timeout = duration || (type === 'info' ? 10000 : 5000);
      setTimeout(() => { alertDiv.style.opacity = '0'; setTimeout(() => alertDiv.remove(), 300); }, timeout);
    }
    
    function escapeHtml(text) { const div = document.createElement('div'); div.textContent = text; return div.innerHTML; }
  </script>
</body>
</html>
